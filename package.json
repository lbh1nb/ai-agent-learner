{
  "name": "ai-coding-learner",
  "version": "1.2.2",
  "description": "AI Coding 学习软件 - 学习如何使用 Agent 编程",
  "author": "lbh1nb",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "icons": "node scripts/generate-icons.js",
    "pack": "vite build && electron-builder --win portable zip",
    "pack:linux": "vite build && electron-builder --linux AppImage deb rpm",
    "pack:mac": "vite build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "echarts": "^5.5.0",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "monaco-editor": "^0.47.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-echarts": "^6.7.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^2.0.0"
  }
}
